<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Markly" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface_container_lowest</item>
        <item name="colorOnSurface">@color/on_surface</item>
    </style>

    <style name="ToolbarTitleAppearance" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textColor">@color/primary_dim</item>
    </style>

    <style name="ToolbarSubtitleAppearance" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">14sp</item>
        <item name="textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    
    <style name="HeadlineAppearance" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textColor">@color/primary_dim</item>
    </style>
    
    <style name="LabelAppearance" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">12sp</item>
        <item name="textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
</resources>