<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|start"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/on_surface_variant"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical|end"
                android:gravity="center_vertical">
                
                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/primary"/>

                <ImageView
                    android:id="@+id/btnExport"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/primary"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CA - R1"
                    android:textColor="@color/primary_dim"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-bold"/>
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MADUA"
                    android:textColor="@color/outline"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>


        </FrameLayout>

        <!-- Search Input -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            android:hint="Search student name or ID..."
            android:background="@drawable/bg_toggle_unselected"
            android:padding="12dp"
            android:textSize="14sp"
            android:visibility="gone"/>

        <!-- Month Navigation -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/tvMonthYear"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="April 2026"
                android:textAppearance="@style/HeadlineAppearance"/>
                
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnPrevMonth"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_container_low"
                android:layout_marginEnd="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@color/primary_dim"/>
            </com.google.android.material.card.MaterialCardView>
            
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNextMonth"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_container_low">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@color/primary_dim"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Horizontal Calendar Strip -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="24dp"
            android:clipToPadding="false"
            android:orientation="horizontal"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAILY ATTENDANCE"
            android:textAppearance="@style/LabelAppearance"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerStudents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"/>
            
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddStudent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:layout_gravity="bottom|end"
        app:elevation="20dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.FloatingActionButton"
        app:backgroundTint="@color/tertiary"
        app:tint="@color/on_tertiary"
        android:src="@android:drawable/ic_input_add"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>